{
	"appId": "me.peanut.app",
	"appName": "Peanut",
	"webDir": "out",
	"android": {
		"allowMixedContent": false,
		"webContentsDebuggingEnabled": true
	},
	"plugins": {
		"CapacitorUpdater": {
			"autoUpdate": true,
			"appReadyTimeout": 15000,
			"responseTimeout": 30,
			"autoDeleteFailed": true,
			"autoDeletePrevious": true
		},
		"CapacitorHttp": {
			"enabled": true
		},
		"CapacitorPasskey": {
			"autoShim": true,
			"origin": "https://staging.peanut.me",
			"domains": [
				"staging.peanut.me"
			]
		}
	}
}
